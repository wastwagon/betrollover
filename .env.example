# BetRollover v2 - Environment Variables
# Copy this file to .env and fill in all values before running.
#
# Quick validation: bash scripts/check-env.sh
#
# ─── Production checklist ────────────────────────────────────────────────────
#   1. JWT_SECRET — generate with: openssl rand -base64 48
#   2. POSTGRES_PASSWORD — use a strong random password
#   3. APP_URL / NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_API_URL — set your domain
#   4. PAYSTACK — use live keys (sk_live_* / pk_live_*)
#   5. SENDGRID_API_KEY — required for email OTP registration
#   6. API_SPORTS_KEY — required for football + volleyball
#   7. ODDS_API_KEY — required for basketball, rugby, MMA, hockey, american football, tennis
#   8. VAPID keys — required for push notifications
#   9. CORS_ORIGINS — add your frontend domain(s)
#   10. Run: bash scripts/pre-deploy-verify.sh before every deploy
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (used by docker-compose and backend)
# Compose enables pg_stat_statements + WAL tuning via postgres `command:` — restart postgres after pulling. Fresh DBs: extension created by database/init/15-pg-stat-statements.sql.
# Existing volume only: docker compose exec postgres psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" -c "CREATE EXTENSION IF NOT EXISTS pg_stat_statements;"
# Optional: DB_POOL_MAX=20, DB_POOL_IDLE_TIMEOUT=30000 for connection pool tuning
# When running the API on your machine and Postgres in Docker Desktop: use POSTGRES_HOST=localhost and POSTGRES_PORT=host port (e.g. 5433 if mapped).
POSTGRES_USER=betrollover
POSTGRES_PASSWORD=betrollover_dev
POSTGRES_DB=betrollover
POSTGRES_PORT=5435
POSTGRES_HOST=localhost

# Redis (docker-compose) — optional Linux VPS host tuning for Redis BGSAVE fork:
# sudo tee /etc/sysctl.d/99-redis.conf <<< 'vm.overcommit_memory = 1' && sudo sysctl --system

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (Sign in with Google) — from Google Cloud Console → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application), add Authorized JavaScript origins (e.g. https://betrollover.com, http://localhost:3000)
# For WebView / WebViewGold (embedded browsers): add Authorized redirect URI on the SAME client:
#   https://YOUR_DOMAIN/api/auth/google/callback
# The Next.js **web** service needs GOOGLE_CLIENT_SECRET for that redirect flow (Coolify: set on web + api).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Same Client ID for frontend (used by Google Sign-In button). Never put GOOGLE_CLIENT_SECRET in frontend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Optional: force redirect-based Google sign-in everywhere (skips GIS widget).
# NEXT_PUBLIC_GOOGLE_WEBVIEW_USE_REDIRECT=1
# Default: phones/tablets use redirect OAuth (WebViewGold-friendly). To use the GIS button on mobile Safari/Chrome instead:
# NEXT_PUBLIC_GOOGLE_USE_GIS_ON_MOBILE=1

# Apple Sign In — from Apple Developer → Certificates, Identifiers & Profiles → Identifiers → Services ID
# Create a Services ID, enable "Sign in with Apple", set Return URL to https://yourdomain.com/api/auth/apple/callback
APPLE_CLIENT_ID=
# Same value for frontend (used to build redirect to Apple).
NEXT_PUBLIC_APPLE_CLIENT_ID=

# API-Sports Football (for fixtures, leagues - tipster platform)
# Get key from https://www.api-football.com/ (dashboard → profile; never commit the real value)
API_SPORTS_KEY=
# Plan profile for API-Sports defaults: free | pro | ultra
# API_SPORTS_PLAN=ultra
# Sync horizon in days (72h = 3)
# API_SYNC_LOOKAHEAD_DAYS=3
# Optional: max fixtures to backfill odds for per sync (default: 100 free / 300 pro / 500 ultra). Set in Coolify env or here.
# API_MAX_FOOTBALL_ODDS_FIXTURES=500

# Paystack (Ghana payments - get from https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# SendGrid Web API (email verification, notifications - get from https://sendgrid.com)
# Create API key at: Settings → API Keys. From address must be a verified sender in SendGrid.
SENDGRID_API_KEY=
SMTP_FROM=noreply@betrollover.com
# Optional: SMTP fallback if SENDGRID_API_KEY not set
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=465
SMTP_USERNAME=apikey

# App
APP_NAME=BetRollover
# Canonical URL users access (Docker: http://localhost:6002, Production: https://betrollover.com).
# On the API server (e.g. api.betrollover.com), set this to the FRONTEND origin for CORS (e.g. https://betrollover.com).
APP_URL=http://localhost:6002
# Public site URL for SEO (Open Graph, sitemap, canonical). Production: https://betrollover.com
NEXT_PUBLIC_APP_URL=http://localhost:6002
# Telegram (@handle without @) — top bar, footer, ad placeholders, admin ads note, JSON-LD sameAs. Default: betrollovertips
# NEXT_PUBLIC_TELEGRAM_ADS_HANDLE=betrollovertips
# Analytics — recommended: Google Tag Manager (add GA4 inside GTM). Fallback: direct GA4 only if GTM unset.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# In GTM: trigger Custom Event `virtual_page_view` for SPA navigations (this app pushes it on route change).
# Optional fallback when GTM is not used:
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
API_PORT=6001
WEB_PORT=6002
# API URL - NEXT_PUBLIC_* is used by web app (browser); set for your deployment
# API base URL (no trailing slash). All routes are under /api/v1 (e.g. .../api/v1/auth/login).
NEXT_PUBLIC_API_URL=http://localhost:6001
API_URL=http://localhost:6001

# Next.js web (`web/`) — optional
# SKIP_WWW_REDIRECT=1     # Staging only: disable www → apex 301 in next.config.js. Omit in production.
# NEXT_BUILD_LOW_MEMORY=1 # Small VPS/Docker: limit static generation parallelism during next build (avoids OOM)
# Production (Docker/Coolify web service only): set to 1 to turn off GTM + GA without rebuilding the image.
# DISABLE_THIRD_PARTY_TAGS=

# Mobile App Links / Universal Links — server-only env for the **web** container (Coolify runtime)
# Serves `/.well-known/assetlinks.json` and `/.well-known/apple-app-site-association` via Next routes (no JSON files needed).
# Android: Play Console → Release → Setup → App integrity → App signing → "App signing key certificate" SHA-256
# APPLE_TEAM_ID: Apple Developer → Membership → Team ID
# ANDROID_SHA256_CERT_FINGERPRINT=AA:BB:CC:...
# ANDROID_PACKAGE_NAME=com.betrollover.app
# APPLE_TEAM_ID=ABCD123456
# APPLE_BUNDLE_ID=com.betrollover.app
# Optional full JSON overrides (must be valid JSON, one line or use Coolify multiline):
# ASSETLINKS_JSON=
# APPLE_APP_SITE_ASSOCIATION_JSON=

COUNTRY=Ghana
CURRENCY=GHS
TIMEZONE=Africa/Accra

# Multi-sport — all 8 sports enabled by default
ENABLED_SPORTS=football,basketball,rugby,mma,volleyball,hockey,american_football,tennis

# Scheduling — set to 'true' to run cron jobs (fixtures, predictions, settlement)
ENABLE_SCHEDULING=true
# football fixture crons (e.g. */6 full sync, */2 odds) use the API process TZ — use e.g. TZ=UTC for logs that match Postgres UTC.
# Prediction scheduling (cron uses this timezone; defaults to Africa/Accra)
PREDICTION_TIMEZONE=Africa/Accra
# Default: 8:00 PM daily prediction generation
PREDICTION_DAILY_CRON=0 20 * * *
# Optional catch-up run if no predictions were created yet
PREDICTION_CATCHUP_CRON=0 2 * * *
# Daily odds refresh before prediction generation
ODDS_FORCE_REFRESH_CRON=45 19 * * *
# Football sync — set to 'false' to skip API-Sports fixture sync (e.g. when football runs on prod)
ENABLE_FOOTBALL_SYNC=true

# CORS — additional allowed origins (comma-separated, production only)
# Example: CORS_ORIGINS=https://app.betrollover.com,https://admin.betrollover.com
CORS_ORIGINS=

# Logging — set to 'info' or 'warn' in production
LOG_LEVEL=info

# Registration uses email OTP (sent via SendGrid above). No phone/SMS required.

# The Odds API — covers basketball, rugby, mma, hockey, american football, tennis (all except football)
# Sign up at https://the-odds-api.com/ → 20K plan ($30/month) recommended for production
# Copy key from https://dash.the-odds-api.com/api-subscriptions
# Run: ./scripts/sync-odds-api-sports.sh to sync all Odds API sports
ODDS_API_KEY=
# Legacy alias — same key, kept for backward compat (docker-compose.prod.yml passes both)
# TENNIS_ODDS_API_KEY=   # Set to same value as ODDS_API_KEY if needed

# Redis (optional for local dev without Docker)
REDIS_URL=redis://localhost:6379

# Web Push (VAPID keys for browser notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# IAP: Not used (web-only). Retained for reference if native apps are added.
# APPLE_SHARED_SECRET=
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Sentry (optional): Error monitoring. When unset, no Sentry code runs.
# NEXT_PUBLIC_SENTRY_DSN=   # Client + server (or use SENTRY_DSN for server only)
# SENTRY_ORG=   # For source map upload (CI)
# SENTRY_PROJECT=   # For source map upload (CI)

# LOG_LEVEL (optional): debug | info | warn | error. When set, backend uses structured JSON logs.
